# Hub WORKER (BullMQ + zamanlayıcı). API ile aynı build, farklı komut.
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist
COPY src/scripts ./src/scripts
CMD ["node", "dist/worker.js"]
