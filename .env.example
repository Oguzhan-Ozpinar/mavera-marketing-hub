# --- Genel ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Dernek registry (tenant_id yerine bu) ---
# JSON dosya yolu; her derneğin Directus URL/token + kanal anahtarları burada.
# Örnek şablon: config/derneks.example.json
DERNEK_REGISTRY_PATH=./config/derneks.json
# Registry şifreliyse (AES-256-GCM) 32 byte key:
CREDENTIAL_ENC_KEY=

# --- Auth ---
JWT_SECRET=degistir-uzun-rastgele-bir-deger

# --- BTS (ORTAK — tüm dernekler tek BTS) ---
BTS_API_URL=
BTS_API_KEY=

# --- Gözlemlenebilirlik ---
SENTRY_DSN=

# --- Webhook güvenliği ---
WEBHOOK_NETGSM_SECRET=
WEBHOOK_MONOCHAT_TOKEN=

# --- Lokal Directus (docker-compose) — sadece şema apply/test için ---
LOCAL_DIRECTUS_URL=http://localhost:8055
LOCAL_DIRECTUS_TOKEN=lokal-admin-token

# BTS bağış ingest (resolveDonor push) doğrulama
WEBHOOK_BTS_SECRET=
